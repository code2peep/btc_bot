TELEGRAM_BOT_TOKEN=123456789:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# Polling interval in seconds.
POLL_INTERVAL_SECONDS=60

# Same asset + same trigger type can only alert once in this cooldown window.
COOLDOWN_HOURS=24

# Trigger thresholds.
DROP_THRESHOLD_PCT=10
WICK_THRESHOLD_PCT=8

# Volume spike assist ratio for wick signal.
WICK_VOLUME_SPIKE_RATIO=1.8

# HTTP timeout in seconds.
REQUEST_TIMEOUT_SECONDS=10

# Yahoo may rate-limit from some networks; this key is used for QQQ fallback candles.
# Replace "demo" with your own TwelveData key for stable long-running production.
TWELVEDATA_API_KEY=demo

# Local state file for dedup/cooldown.
STATE_FILE=alert_state.json

# true/false: if true, run one cycle then exit (for smoke test).
RUN_ONCE=false

# Optional: DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO
